<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>
        Query Meals
    </title>
</head>
<body>
    <h1>Query Meals</h1>

    <form id="proteinQueryForm">
        <label>Show meals with protein equal to or greater than:
            <input type="number" id="minProtein" name="minProtein" min="0" />
        </label>
        <button type="submit">Search</button>
    </form>

    <form id="sugarQueryForm">
        <label>Show meals with sugar less than:
            <input type="number" id="maxSugar" name="maxSugar" min="0" />
        </label>
        <button type="submit">Search</button>
    </form>

    <h2>Results</h2>
    <ul id="results"></ul>

    <p><a href="/upload">Upload Meal</a></p>
    <p><a href="/list">View All Meals</a></p>

    <script>
        const proteinForm = document.getElementById("proteinQueryForm");
        const sugarForm = document.getElementById("sugarQueryForm");
        const results = document.getElementById("results");

        async function renderResults(url) {
            const response = await fetch(url);
            const meals = await response.json();

            results.innerHTML = "";

            if (meals.length === 0) {
                const li = document.createElement("li");
                li.textContent = "No meals matched your search.";
                results.appendChild(li);
                return;
            }

            meals.forEach((meal) => {
                const li = document.createElement("li");
                li.textContent = `Meal Name: ${meal.mealName || "Unnamed Meal"}, Protein: ${meal.protein} (g), Carbs: ${meal.carbs} (g), Fats: ${meal.fats} (g), Sugar: ${meal.sugar} (g), Notes: ${meal.notes}`;
                results.appendChild(li);
            });
        }

        proteinForm.addEventListener("submit", async (event) => {
            event.preventDefault();

            const minProtein = document.getElementById("minProtein").value;
            const searchParams = new URLSearchParams();

            if (minProtein !== "") {
                searchParams.set("minProtein", minProtein);
            }

            await renderResults(`/meals?${searchParams.toString()}`);
        });

        sugarForm.addEventListener("submit", async (event) => {
            event.preventDefault();

            const maxSugar = document.getElementById("maxSugar").value;
            const searchParams = new URLSearchParams();

            if (maxSugar !== "") {
                searchParams.set("maxSugar", maxSugar);
            }

            await renderResults(`/meals?${searchParams.toString()}`);
        });
    </script>
</body>
</html>
